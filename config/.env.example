# Hermes-Secrets – Messenger-Konfiguration
# Diese Datei als config/.env speichern (wird nicht eingecheckt)

# ── Telegram ────────────────────────────────────────────────────────────────

# Bot-Token aus @BotFather
TELEGRAM_BOT_TOKEN=

# Kommagetrennte Telegram-User-IDs, die den Bot nutzen dürfen
TELEGRAM_ALLOWED_USERS=

# Telegram-Channel-ID für Home-Channel (Format: -100xxxxxxxxxx)
TELEGRAM_HOME_CHANNEL=

# Anzeigename des Home-Channels
TELEGRAM_HOME_CHANNEL_NAME=

# ── Signal ───────────────────────────────────────────────────────────────────

# URL der signal-cli REST API (erforderlich)
SIGNAL_HTTP_URL=

# Absender-Nummer im E.164-Format (erforderlich)
SIGNAL_ACCOUNT=

# Kommagetrennte E.164-Nummern oder UUIDs, die den Bot nutzen dürfen
SIGNAL_ALLOWED_USERS=

# Gruppen-IDs, die den Bot nutzen dürfen (weglassen = deaktiviert, * = alle)
SIGNAL_GROUP_ALLOWED_USERS=

# Standard-Empfänger für Cron-Jobs
SIGNAL_HOME_CHANNEL=

# ── Mattermost ───────────────────────────────────────────────────────────────

# URL der Mattermost-Instanz (erforderlich)
MATTERMOST_URL=

# Bot-Token (erforderlich)
MATTERMOST_TOKEN=

# Kommagetrennte User-IDs, die den Bot nutzen dürfen (erforderlich)
MATTERMOST_ALLOWED_USERS=

# Antwort-Modus: thread = in Thread antworten, off = direkter Post (Standard: off)
# MATTERMOST_REPLY_MODE=thread

# @-Erwähnung erforderlich (false = Bot antwortet immer, Standard: true)
# MATTERMOST_REQUIRE_MENTION=false

# Channel-IDs, in denen der Bot ohne @-Erwähnung antwortet (kommagetrennt)
# MATTERMOST_FREE_RESPONSE_CHANNELS=channel_id_1,channel_id_2
